# Copy this file to .env and fill in real values. Never commit .env.

# --- MetaTrader 5 ---
# Leave MT5_LOGIN blank to attach to an already-running, logged-in terminal.
# Fill all three to have the app log in to a specific account.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Optional: full path to terminal64.exe if not auto-detected
MT5_TERMINAL_PATH=

# --- Telegram ---
# Create a bot via @BotFather to get the token.
# Get your chat id by messaging the bot then calling getUpdates, or via @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram ids allowed to run admin bot commands (e.g. yours).
BOT_ADMIN_IDS=
# Crypto payment details shown by /subscribe.
CRYPTO_WALLET_ADDRESS=
CRYPTO_CURRENCY=USDT
PRICE_MONTHLY=20
PRICE_QUARTERLY=50
# CryptoBot / CryptoPay auto-confirmed payments (recommended). Get a token from
# @CryptoBot -> Crypto Pay -> Create App. Leave blank to use the manual flow.
CRYPTOPAY_TOKEN=
CRYPTOPAY_TESTNET=false
CRYPTOPAY_ASSET=USDT

# --- Risk Rules (defaults from PRD; adjust as needed) ---
MAX_TRADES_PER_DAY=2
MAX_DAILY_LOSS_PCT=5
MAX_RISK_PER_TRADE_PCT=4
MAX_CONSECUTIVE_LOSSES=2
MAX_ACCOUNT_EXPOSURE_PCT=5

# --- Enforcement (V2) ---
# dry_run = detect + alert only (NO real trading action). live = actually
# close positions and lock the account. KEEP THIS dry_run until you trust it.
ENFORCEMENT_MODE=dry_run
# Background risk-check interval in seconds (0 disables the auto-checker).
RISK_CHECK_INTERVAL_SECONDS=30
LOCK_STATE_PATH=data/lock_state.json

# --- Terminal farm provisioning (multi-account VPS) ---
# Folder of a base MT5 install to clone for each account (contains terminal64.exe),
# e.g. C:\Program Files\MetaTrader 5
BASE_TERMINAL_DIR=
# Where per-account portable terminal copies are created.
TERMINALS_ROOT=terminals
# Set true on the VPS to auto-create a terminal per account on worker startup.
AUTO_PROVISION=false

# --- Database (Phase A, multi-user) ---
# Dev default is SQLite (leave as-is). Production = PostgreSQL:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/zanzer
DATABASE_URL=sqlite+aiosqlite:///./data/zanzer.db
# Fernet key for encrypting stored MT5 credentials (REQUIRED in production).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Shared secret for /admin/* endpoints (sent as X-Admin-Token header).
ADMIN_TOKEN=
# 0 = no free trial (users start inactive until paid or admin-activated).
TRIAL_DAYS=0

# --- AI Performance Coach (Hermes, Phase 6) ---
# OpenAI API key enables /coach (weekly AI psychology/discipline review).
# Leave blank to disable the coach gracefully.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_COACH_ENABLED=true

# --- App ---
APP_ENV=development
